{
  "mcpServers": {
    "chrome-devtools": {
      "type": "stdio",
      "command": "npx",
      "args": [
        "-y",
        "chrome-devtools-mcp@latest",
        "--browser-url=http://127.0.0.1:9222",
        "--no-usage-statistics"
      ],
      "env": {
        "SystemRoot": "C:\\Windows",
        "PROGRAMFILES": "C:\\Program Files",
        "CHROME_DEVTOOLS_MCP_NO_UPDATE_CHECKS": "1"
      }
    },
    "jcodemunch": {
      "type": "stdio",
      "command": "uvx",
      "args": ["jcodemunch-mcp"],
      "env": {}
    },
    "supabase": {
      "type": "url",
      "url": "https://mcp.supabase.com/sse",
      "headers": {
        "Authorization": "Bearer ${SUPABASE_SERVICE_KEY}"
      }
    },
    "mcp2cli": {
      "type": "stdio",
      "command": "uvx",
      "args": ["mcp2cli", "--mcp-stdio", "uvx mcp2cli --help"],
      "env": {}
    },
    "nwkids-infrastructure": {
      "type": "stdio",
      "command": "pnpm",
      "args": ["--filter", "@nwkids/mcp", "start"],
      "env": {}
    },
    "gbrain": {
      "type": "stdio",
      "command": "gbrain",
      "args": ["serve"],
      "env": {}
    }
  }
}
