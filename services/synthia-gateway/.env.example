# Synthia Gateway — Environment Configuration
# Copy this file to .env and fill in the values that apply to your setup.

# ─── Server ──────────────────────────────────────────────────────────────────
PORT=3000
NODE_ENV=development

# ─── Gateway Authentication (optional) ────────────────────────────────────────
# When set, every request must carry this key as:
#   Authorization: Bearer <GATEWAY_API_KEY>
# and provider keys are taken from the variables below.
# When left blank, the Authorization header is forwarded to the provider directly
# (pass-through mode — the caller supplies their own provider key).
GATEWAY_API_KEY=

# ─── Provider API keys (used only when GATEWAY_API_KEY is set) ───────────────
OPENAI_API_KEY=sk-...
ANTHROPIC_API_KEY=sk-ant-...
GROQ_API_KEY=gsk_...
MISTRAL_API_KEY=...
TOGETHER_API_KEY=...

# ─── Custom base URLs ─────────────────────────────────────────────────────────
# Override the default base URL for any provider.
# Useful for Azure OpenAI, LM Studio, or other OpenAI-compatible servers.
OPENAI_BASE_URL=https://api.openai.com
ANTHROPIC_BASE_URL=https://api.anthropic.com
GROQ_BASE_URL=https://api.groq.com/openai
MISTRAL_BASE_URL=https://api.mistral.ai
TOGETHER_BASE_URL=https://api.together.xyz
# Local Ollama instance
OLLAMA_BASE_URL=http://localhost:11434

# ─── Default provider ─────────────────────────────────────────────────────────
# Used when the model name does not match any known pattern.
# One of: openai | anthropic | groq | mistral | together | ollama
DEFAULT_PROVIDER=openai

# ─── Logging ──────────────────────────────────────────────────────────────────
# "combined" | "dev" | "tiny" | "silent"
LOG_LEVEL=dev
