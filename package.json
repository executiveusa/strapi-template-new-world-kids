{
  "name": "new-world-kids-platform",
  "version": "3.0.0",
  "private": true,
  "author": {
    "name": "Notum Technologies",
    "email": "info@notum.cz",
    "url": "https://notum.cz"
  },
  "maintainers": [
    {
      "name": "Notum Technologies",
      "email": "info@notum.cz",
      "url": "https://notum.cz"
    }
  ],
  "scripts": {
    "build": "turbo run build --filter=@repo/ui --filter=@repo/blog --filter=@repo/hermes --cache-dir=.turbo",
    "build:blog": "turbo run build --filter=@repo/blog",
    "build:hermes": "turbo run build --filter=@repo/hermes",
    "build:ui": "turbo run build --filter=@repo/ui",
    "build:ui:static": "NODE_OPTIONS=--max-old-space-size=2048 turbo run build:static --filter=@repo/ui",
    "commit": "git-cz",
    "dev": "turbo run dev --filter=@repo/ui --filter=@repo/blog --filter=@repo/hermes",
    "dev:blog": "turbo run dev --filter=@repo/blog",
    "dev:hermes": "turbo run dev --filter=@repo/hermes",
    "dev:ui": "turbo run dev --filter=@repo/ui",
    "format": "prettier --write --cache --ignore-unknown \"**/(*.{md,css,scss}|*.package.json)\"",
    "format:check": "prettier --check --cache --ignore-unknown \"**/(*.{md,css,scss}|*.package.json)\"",
    "preinstall": "npx only-allow pnpm",
    "postinstall": "pnpm run setup:apps",
    "lint": "turbo run lint --filter=@repo/ui --filter=@repo/blog --filter=@repo/hermes --filter=@repo/shared-data",
    "lint:fix": "turbo run lint:fix --filter=@repo/ui --filter=@repo/blog --filter=@repo/hermes --filter=@repo/shared-data",
    "prepare": "husky",
    "setup:apps": "node scripts/setup-apps.mjs",
    "start:blog": "turbo run start --filter=@repo/blog",
    "start:hermes": "turbo run start --filter=@repo/hermes",
    "start:ui": "turbo run start --filter=@repo/ui",
    "test": "turbo run test --filter=@repo/ui --filter=@repo/blog --filter=@repo/hermes",
    "test:blog": "turbo run test --filter=@repo/blog",
    "test:ci": "turbo run test --filter=@repo/ui --filter=@repo/blog --filter=@repo/hermes",
    "test:hermes": "turbo run test --filter=@repo/hermes",
    "test:ui": "turbo run test --filter=@repo/ui",
    "tests:lhci:perfo": "turbo run lhci-perfo-check --filter=@repo/tests-playwright",
    "tests:playwright:axe": "turbo run axe-test --filter=@repo/tests-playwright",
    "tests:playwright:e2e:test": "turbo run playwright-e2e-tests --filter=@repo/tests-playwright",
    "tests:playwright:e2e:test:interactive": "turbo run playwright-interactive-mode --filter=@repo/tests-playwright",
    "tests:playwright:seo": "pnpm -F @repo/tests-playwright exec playwright test --project=seo",
    "tests:playwright:visual": "turbo run playwright-visual-tests --filter=@repo/tests-playwright",
    "typecheck": "turbo run typecheck --filter=@repo/ui --filter=@repo/blog --filter=@repo/hermes --filter=@repo/shared-data"
  },
  "devDependencies": {
    "@commitlint/cli": "19.3.0",
    "@commitlint/config-conventional": "19.8.1",
    "@commitlint/config-pnpm-scopes": "20.1.0",
    "@repo/eslint-config": "workspace:*",
    "@repo/semantic-release-config": "workspace:*",
    "@repo/typescript-config": "workspace:*",
    "commitizen": "4.3.1",
    "cz-conventional-changelog": "3.3.0",
    "eslint": "^9.39.2",
    "husky": "9.1.7",
    "lint-staged": "15.2.7",
    "prettier": "3.8.1",
    "semantic-release": "24.2.0",
    "turbo": "2.7.6"
  },
  "packageManager": "pnpm@10.28.1",
  "engines": {
    "node": "^22.0.0"
  },
  "pnpm": {
    "overrides": {
      "@types/react": "19.2.9",
      "@types/react-dom": "19.2.3"
    },
    "packageExtensions": {
      "@hookform/resolvers": {
        "peerDependencies": {
          "zod": "*"
        }
      }
    }
  }
}
