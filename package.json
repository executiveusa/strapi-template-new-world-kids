{
  "name": "new-world-kids-platform",
  "version": "3.0.0",
  "private": true,
  "author": {
    "name": "Notum Technologies",
    "email": "info@notum.cz",
    "url": "https://notum.cz"
  },
  "maintainers": [
    {
      "name": "Notum Technologies",
      "email": "info@notum.cz",
      "url": "https://notum.cz"
    }
  ],
  "scripts": {
    "browser:chrome": "powershell -ExecutionPolicy Bypass -File ./browser-control/scripts/start-chrome-remote-debugging.ps1",
    "browser:setup": "powershell -ExecutionPolicy Bypass -File ./browser-control/scripts/setup-browser-control.ps1",
    "browser:setup:devtools": "powershell -ExecutionPolicy Bypass -File ./browser-control/scripts/install-chrome-devtools-mcp.ps1",
    "browser:setup:harness": "powershell -ExecutionPolicy Bypass -File ./browser-control/scripts/install-browser-harness.ps1",
    "browser:setup:playwright": "powershell -ExecutionPolicy Bypass -File ./browser-control/scripts/install-playwright.ps1",
    "browser:setup:selenium": "powershell -ExecutionPolicy Bypass -File ./browser-control/scripts/install-selenium.ps1",
    "browser:verify": "powershell -ExecutionPolicy Bypass -File ./browser-control/scripts/verify-browser-control.ps1",
    "build": "turbo run build --filter=@repo/blog --filter=@repo/hermes --filter=@nwkids/mcp --cache-dir=.turbo",
    "build:blog": "turbo run build --filter=@repo/blog",
    "build:ui": "turbo run build --filter=@repo/ui",
    "build:hermes": "turbo run build --filter=@repo/hermes",
    "build:mcp": "turbo run build --filter=@nwkids/mcp",
    "build:blog:static": "NODE_OPTIONS=--max-old-space-size=2048 turbo run build --filter=@repo/blog",
    "commit": "git-cz",
    "dev": "turbo run dev --filter=@repo/blog --filter=@repo/hermes",
    "dev:blog": "turbo run dev --filter=@repo/blog",
    "dev:hermes": "turbo run dev --filter=@repo/hermes",
    "dev:mcp": "turbo run dev --filter=@nwkids/mcp",
    "format": "prettier --write --cache --ignore-unknown \"**/(*.{md,css,scss}|*.package.json)\"",
    "format:check": "prettier --check --cache --ignore-unknown \"**/(*.{md,css,scss}|*.package.json)\"",
    "preinstall": "npx only-allow pnpm",
    "postinstall": "node -e \"if (!process.env.VERCEL) { require('child_process').spawnSync('pnpm', ['run', 'setup:apps'], { stdio: 'inherit' }); }\"",
    "lint": "turbo run lint --filter=@repo/blog --filter=@repo/hermes --filter=@repo/shared-data --filter=@nwkids/mcp",
    "lint:fix": "turbo run lint:fix --filter=@repo/blog --filter=@repo/hermes --filter=@repo/shared-data --filter=@nwkids/mcp",
    "prepare": "husky",
    "setup:apps": "node scripts/setup-apps.mjs",
    "start:blog": "turbo run start --filter=@repo/blog",
    "start:hermes": "turbo run start --filter=@repo/hermes",
    "start:mcp": "turbo run start --filter=@nwkids/mcp",
    "test": "turbo run test --filter=@repo/blog --filter=@repo/hermes --filter=@nwkids/mcp",
    "test:blog": "turbo run test --filter=@repo/blog",
    "test:ci": "turbo run test --filter=@repo/blog --filter=@repo/hermes",
    "test:hermes": "turbo run test --filter=@repo/hermes",
    "test:mcp": "turbo run test --filter=@nwkids/mcp",
    "tests:lhci:perfo": "turbo run lhci-perfo-check --filter=@repo/tests-playwright",
    "tests:playwright:axe": "turbo run axe-test --filter=@repo/tests-playwright",
    "tests:playwright:e2e:test": "turbo run playwright-e2e-tests --filter=@repo/tests-playwright",
    "tests:playwright:e2e:test:interactive": "turbo run playwright-interactive-mode --filter=@repo/tests-playwright",
    "tests:playwright:seo": "pnpm -F @repo/tests-playwright exec playwright test --project=seo",
    "tests:playwright:visual": "turbo run playwright-visual-tests --filter=@repo/tests-playwright",
    "typecheck": "turbo run typecheck --filter=@repo/blog --filter=@repo/hermes --filter=@repo/shared-data --filter=@nwkids/mcp"
  },
  "devDependencies": {
    "@commitlint/cli": "19.3.0",
    "@commitlint/config-conventional": "19.8.1",
    "@commitlint/config-pnpm-scopes": "20.1.0",
    "@repo/eslint-config": "workspace:*",
    "@repo/semantic-release-config": "workspace:*",
    "@repo/typescript-config": "workspace:*",
    "commitizen": "4.3.1",
    "cz-conventional-changelog": "3.3.0",
    "eslint": "^9.39.2",
    "husky": "9.1.7",
    "lint-staged": "15.2.7",
    "next": "16.1.5",
    "prettier": "3.8.1",
    "prettier-plugin-tailwindcss": "^0.7.4",
    "semantic-release": "24.2.0",
    "turbo": "2.7.6"
  },
  "packageManager": "pnpm@10.28.1",
  "engines": {
    "node": "^22.0.0"
  },
  "pnpm": {
    "overrides": {
      "@types/react": "19.2.9",
      "@types/react-dom": "19.2.3"
    },
    "packageExtensions": {
      "@hookform/resolvers": {
        "peerDependencies": {
          "zod": "*"
        }
      }
    }
  }
}
